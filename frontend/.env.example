# Backend API prefix used by every Axios request.
VITE_API_BASE_URL=http://localhost:5000/api
# Login destination used after an expired or invalid session.
VITE_REDIRECT_URL=http://localhost:5173/login
VITE_COOKIE_DOMAIN=
VITE_SECRET_KEY=replace-for-your-environment

# Vercel production values:
# VITE_API_BASE_URL=https://www.ops.technovani.com/api
# VITE_REDIRECT_URL=https://www.ops.notioninsurance.in/login
# VITE_COOKIE_DOMAIN=.notioninsurance.in
